# Optional: Socrata app token for higher rate limits (1000 req/hr without, higher with)
# Register at https://data.oaklandca.gov/profile/edit/developer_settings
SOCRATA_APP_TOKEN=

# Required for the web app chat interface (not needed for MCP server alone)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: Override the default model (default: anthropic/claude-sonnet-4)
# See available models at https://openrouter.ai/models
# OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Required for the remote (Vercel) MCP server — bearer token clients must send.
# Generate a random value, e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`
MCP_AUTH_TOKEN=
